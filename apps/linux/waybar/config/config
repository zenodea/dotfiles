{
  "layer": "top",
  "height": 28,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock"  // Add clock module to the center
  ],
"clock": {
  "interval": 30,
  "format": "{:%I:%M %p}",
  "tooltip-format": "{:%a, %d %b %G}"
},

  "modules-right": [
    "power-profiles-daemon",
    "pulseaudio",
    "backlight",
    "bluetooth",
    "custom/mullvad",
    "network",
    "custom/net-graph",
    "battery",
    "custom/power"
  ],
  "hyprland/window": {
    "max-length": 30
  },
  "hyprland/language": {
    "format-en": "En",
    "format-ru": "Ru"
  },
  "tray": {
    "icon-size": 20,
