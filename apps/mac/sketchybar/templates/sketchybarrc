#!/bin/bash

source "$HOME/.config/sketchybar/colors.sh" # Loads all defined colors
source "$HOME/.config/sketchybar/icons.sh"  # Loads all defined icons
source "$HOME/.config/sketchybar/styles.sh" # Shared item styling (popup rows)

ITEM_DIR="$HOME/.config/sketchybar/items"     # Directory where the items are configured
PLUGIN_DIR="$HOME/.config/sketchybar/plugins" # Directory where all the plugin scripts are stored

FONT="SF Pro" # Needs to have Regular, Bold, Semibold, Heavy and Black variants
PADDINGS=3    # All paddings use this value (icon, label, background)

# Suppress the macOS on-screen volume overlay â€” the bar already shows volume.
#
# `launchctl unload` (what this used to do) is a deprecated API that fails with
# "Input/output error" on current macOS, and `bootout` is refused outright by
# SIP. `disable` is the one that still takes: it's persistent, so launchd won't
# spawn the helper on the next volume keypress.
#
# Caveat: OSDUIHelper draws *every* HUD, so brightness and caps-lock lose theirs
# too. Undo with:
#   launchctl enable gui/$(id -u)/com.apple.OSDUIHelper
launchctl disable "gui/$(id -u)/com.apple.OSDUIHelper" > /dev/null 2>&1 &

# Setting up the general bar appearance of the bar
bar=(
  height=33
  color=$BAR_COLOR
  shadow=on
  position=top
  sticky=on
  padding_right=10
  padding_left=10
  corner_radius=9
  y_offset=2
  margin=7
  border_width=1
  border_color=0xff${GREEN}
  blur_radius=30
  notch_width=0
)

sketchybar --bar "${bar[@]}"

# Setting up default values
defaults=(
  updates=when_shown
  icon.font="$FONT:Bold:14.0"
  icon.color=$ICON_COLOR
  icon.padding_left=$PADDINGS
  icon.padding_right=$PADDINGS
  label.font="$FONT:Semibold:13.0"
  label.color=$LABEL_COLOR
  label.padding_left=$PADDINGS
  label.padding_right=$PADDINGS
  padding_right=$PADDINGS
  padding_left=$PADDINGS
  background.height=30
  popup.blur_radius=0
  background.corner_radius=9
  popup.background.border_width=2
  popup.background.corner_radius=9
  popup.background.border_color=$GREEN
  popup.background.color=$POPUP_BACKGROUND_COLOR
  popup.blur_radius=20
  popup.background.shadow.drawing=on
)

sketchybar --default "${defaults[@]}"

# Left
source "$ITEM_DIR/apple.sh"
source "$ITEM_DIR/aerospace.sh"
source "$ITEM_DIR/spaces.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/label.sh"
source "$ITEM_DIR/music.sh"


# Right
source "$ITEM_DIR/calendar.sh"
source "$ITEM_DIR/brew.sh"
source "$ITEM_DIR/github.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/mic.sh"
source "$ITEM_DIR/network.sh"
# Right-side items are laid out right to left in the order they're added, so
# sourcing the graphs last lands them left of the status bracket, in their own
# box.
source "$ITEM_DIR/network_graph.sh"

# Forcing all item scripts to run (never do this outside of sketchybarrc)
sketchybar --update

echo "sketchybar configuation loaded.."
