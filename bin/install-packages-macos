#!/usr/bin/env bash
# install-packages-macos — install every package the macOS setup needs, then
# register sketchybar and borders as login services so the bar and the window
# borders come up on their own.
set -e

has() { command -v "$1" &> /dev/null; }

# ── Bootstrap Homebrew ───────────────────────────────────────────────────────

if ! has brew; then
    echo "==> Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # The installer doesn't touch the current shell's PATH.
    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"   # Apple silicon
    else
        eval "$(/usr/local/bin/brew shellenv)"      # Intel
    fi
fi

# ── Taps ─────────────────────────────────────────────────────────────────────

echo "==> Tapping..."
brew tap felixkratz/formulae   # sketchybar, borders
brew tap nikitabobko/tap       # aerospace

# ── Formulae ─────────────────────────────────────────────────────────────────

FORMULAE=(
    # Status bar + window borders (both run as services, see below)
    felixkratz/formulae/sketchybar
    felixkratz/formulae/borders

    # The sketchybar config shells out to these on every update:
    #   jq              — parsing --query output in the plugins
    #   gh              — the github.bell notification popup
    #   switchaudio-osx — SwitchAudioSource, the volume right-click device picker
    # macOS 26 does ship its own /usr/bin/jq, but older ones don't.
    jq
    gh
    switchaudio-osx

    # Now-playing for the music item. sketchybar's own media_change event is
    # dead on macOS 15.4+ (Apple locked the MediaRemote framework); this reaches
    # the same service through a signed adapter that still works.
    media-control

    # Editors
    neovim

    # Git tooling
    git
    lazygit

    # File managers
    vifm
    yazi

    # Terminal multiplexer
    tmux

    # Search
    ripgrep

    # Runtimes
    node
    pyenv
    rbenv
    rust
)

echo "==> Installing formulae..."
brew install "${FORMULAE[@]}"

# ── Casks ────────────────────────────────────────────────────────────────────

CASKS=(
    # Tiling window manager
    nikitabobko/tap/aerospace

    # Terminal
    ghostty

    # Editors
    zed

    # Launcher
    alfred

    # Browser
    firefox

    # Notes
    obsidian

    # Fonts. sketchybar's icons are SF Symbols glyphs from the private-use
    # range — without SF Pro every icon in the bar renders as an empty box.
    font-sf-pro
    font-hack-nerd-font
)

echo "==> Installing casks..."
brew install --cask "${CASKS[@]}"

# ── Services ─────────────────────────────────────────────────────────────────

# `brew services start` registers a LaunchAgent, so these come back on login
# and after a crash — not just for this session.
echo "==> Starting services..."
brew services start felixkratz/formulae/sketchybar
brew services start felixkratz/formulae/borders

# AeroSpace is a .app, not a brew service; it starts itself at login only if its
# own config says so. That config lives in apps/mac/aerospace/.
if ! grep -q "^start-at-login = true" "$HOME/.config/aerospace/aerospace.toml" 2> /dev/null; then
    echo "    note: aerospace won't start at login — set start-at-login = true"
    echo "          in apps/mac/aerospace/config/aerospace.toml to change that"
fi

echo "Done. Run ./install.sh next to link the configs and render a theme."
