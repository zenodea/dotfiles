#!/bin/bash

# scripts → linux → home → repo root
DOTFILES_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../../.." && pwd)"
DOTFILES="$DOTFILES_DIR/bin/dotfiles"

THEMES="󰔯  Themes"
LOCK="󰌾  Lock"
SUSPEND="󰤄  Suspend"
LOGOUT="󰍃  Logout"
REBOOT="󰑓  Reboot"
SHUTDOWN="󰐥  Shutdown"

POWER_MENU_ARGS=(
    -p ""
    -hover-select
    -me-select-entry MousePrimary
    -me-accept-entry MouseDPrimary
    -kb-row-down "Down,Control+n,j"
    -kb-row-up "Up,Control+p,k"
    -kb-accept-entry "Control+j,Control+m,Return,KP_Enter,l"
    -kb-cancel "Escape,Control+g,Control+bracketleft,h"
    -theme "$HOME/.config/rofi/themes/power-menu.rasi"
)

# Build list of theme names in sorted order
mapfile -t theme_names < <("$DOTFILES" --themes-plain)

build_display_list() {
    local current="$1"
    for name in "${theme_names[@]}"; do
        if [[ "$name" == "$current" ]]; then
            echo "●  $name"
        else
            echo "   $name"
        fi
    done
}

show_theme_picker() {
    local current
    current="$("$DOTFILES" --current)"

    local idx
    idx=$(build_display_list "$current" | rofi -dmenu \
        -format i \
        -p "" \
        -hover-select \
        -me-select-entry MousePrimary \
        -me-accept-entry MouseDPrimary \
        -kb-row-down "Down,Control+n,j" \
        -kb-row-up "Up,Control+p,k" \
        -kb-accept-entry "Control+j,Control+m,Return,KP_Enter,l" \
        -kb-cancel "Escape,Control+g,Control+bracketleft,h" \
        -theme "$HOME/.config/rofi/themes/theme-picker.rasi")

    [[ -z "$idx" ]] && return

    local theme="${theme_names[$idx]}"
    [[ -n "$theme" ]] && "$DOTFILES" --theme "$theme"
}

# Main power menu
chosen=$(printf "%s\n" "$THEMES" "$LOCK" "$SUSPEND" "$LOGOUT" "$REBOOT" "$SHUTDOWN" | \
    rofi -dmenu "${POWER_MENU_ARGS[@]}")

case "$chosen" in
    "$THEMES")   show_theme_picker ;;
    "$LOCK")     hyprlock ;;
    "$SUSPEND")  systemctl suspend ;;
    "$LOGOUT")   hyprctl dispatch exit ;;
    "$REBOOT")   systemctl reboot ;;
    "$SHUTDOWN") systemctl poweroff ;;
esac
